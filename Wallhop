-- Helper: ON/OFF toggle button row inside scroll

local function makeToggleRow(labelText, initState, yPos, onChanged)

    local lbl = Instance.new("TextLabel")

    lbl.Size              = UDim2.new(0.58, 0, 0, 22)

    lbl.Position          = UDim2.new(0, 12, 0, yPos)

    lbl.BackgroundTransparency = 1

    lbl.Text              = labelText

    lbl.TextColor3        = C.TextSub

    lbl.TextSize          = 11

    lbl.Font              = Enum.Font.Gotham

    lbl.TextXAlignment    = Enum.TextXAlignment.Left

    lbl.Parent            = sScroll



    local btn = Instance.new("TextButton")

    btn.Size             = UDim2.new(0.36, 0, 0, 22)

    btn.Position         = UDim2.new(0.62, 0, 0, yPos)

    btn.BackgroundColor3 = initState and Color3.fromRGB(20,40,30) or C.Surface

    btn.Text             = initState and "ON" or "OFF"

    btn.TextColor3       = initState and C.Green or C.Red

    btn.TextSize         = 11

    btn.Font             = Enum.Font.GothamBold

    btn.Parent           = sScroll

    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5)

    local st = Instance.new("UIStroke", btn)

    st.Color = initState and C.Green or C.Border



    local state = initState

    btn.MouseButton1Click:Connect(function()

        state = not state

        TweenService:Create(btn, TweenInfo.new(0.12), {

            BackgroundColor3 = state and Color3.fromRGB(20,40,30) or C.Surface

        }):Play()

        TweenService:Create(st, TweenInfo.new(0.12), {

            Color = state and C.Green or C.Border

        }):Play()

        btn.Text       = state and "ON" or "OFF"

        btn.TextColor3 = state and C.Green or C.Red

        onChanged(state)

    end)

    return btn, st

end



-- Helper: keybind row (click to remap)

local function makeKeybindRow(labelText, getCurrentKey, yPos, setKey)

    local lbl = Instance.new("TextLabel")

    lbl.Size              = UDim2.new(0.55, 0, 0, 22)

    lbl.Position          = UDim2.new(0, 12, 0, yPos)

    lbl.BackgroundTransparency = 1

    lbl.Text              = labelText

    lbl.TextColor3        = C.TextSub

    lbl.TextSize          = 11

    lbl.Font              = Enum.Font.Gotham

    lbl.TextXAlignment    = Enum.TextXAlignment.Left

    lbl.Parent            = sScroll



    local btn = Instance.new("TextButton")

    btn.Size             = UDim2.new(0.40, 0, 0, 22)

    btn.Position         = UDim2.new(0.58, 0, 0, yPos)

    btn.BackgroundColor3 = C.Surface

    btn.Text             = getCurrentKey().Name

    btn.TextColor3       = C.TextMain

    btn.TextSize         = 10

    btn.Font             = Enum.Font.GothamBold

    btn.Parent           = sScroll

    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5)

    local bst = Instance.new("UIStroke", btn)

    bst.Color = C.Border



    btn.MouseButton1Click:Connect(function()

        if rebindTarget then return end  -- already listening

        rebindTarget   = btn

        rebindCallback = function(kc)

            setKey(kc)

            btn.Text       = kc.Name

            btn.TextColor3 = C.TextMain

            TweenService:Create(bst, TweenInfo.new(0.12), {Color = C.Green}):Play()

            task.delay(0.6, function()

                TweenService:Create(bst, TweenInfo.new(0.3), {Color = C.Border}):Play()

            end)

        end

        btn.Text       = "..."

        btn.TextColor3 = Color3.fromRGB(255, 200, 50)

        TweenService:Create(bst, TweenInfo.new(0.12), {

            Color = Color3.fromRGB(255, 200, 50)

        }):Play()

    end)

end




local function updateModes()
    mode1Stroke.Color = (currentMode == 1) and activeColor or inactiveColor
    mode1Label.TextColor3 = (currentMode == 1) and activeColor or inactiveColor
    mode2Stroke.Color = (currentMode == 2) and activeColor or inactiveColor
    mode2Label.TextColor3 = (currentMode == 2) and activeColor or inactiveColor
end

local function toggleEnabled()
    enabled = not enabled
    if enabled then
        status.Text = "ON"
        status.TextColor3 = activeColor
        mainStroke.Color = activeColor
        mainStroke.Thickness = 1.8
    else
        status.Text = "OFF"
        status.TextColor3 = offColor
        mainStroke.Color = blueColor
        mainStroke.Thickness = 1.5
    end
end


-- Settings drag (title bar only — scroll handles its own input)

local settingsDragStart = nil

local settingsStartPos  = nil

settingsTitle.InputBegan:Connect(function(input)

    if input.UserInputType == Enum.UserInputType.MouseButton1 then

        settingsDragStart = input.Position

        settingsStartPos  = settingsFrame.Position

    end

end)

UserInputService.InputChanged:Connect(function(input)

    if not settingsDragStart then return end

    if input.UserInputType ~= Enum.UserInputType.MouseMovement then return end

    local d = input.Position - settingsDragStart

    settingsFrame.Position = UDim2.new(

        settingsStartPos.X.Scale, settingsStartPos.X.Offset + d.X,

        settingsStartPos.Y.Scale, settingsStartPos.Y.Offset + d.Y

    )

end)

settingsTitle.InputEnded:Connect(function(input)

    if input.UserInputType == Enum.UserInputType.MouseButton1 then

        settingsDragStart = nil

    end

end)




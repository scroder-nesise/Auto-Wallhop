    end
end)

local function hasWall(root)
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {root.Parent}
    local dirs = {
        root.CFrame.RightVector * 5,
        -root.CFrame.RightVector * 5,
        root.CFrame.LookVector * 5,
        -root.CFrame.LookVector * 5
    }
    for _, dir in ipairs(dirs) do
        local result = Workspace:Raycast(root.Position + Vector3.new(0, -2, 0), dir, rayParams)
        if result and result.Instance.CanCollide then return true end
    end
    return false
end

local function getContact(char, root)
    local p = OverlapParams.new()
    p.FilterDescendantsInstances = {char}
    p.FilterType = Enum.RaycastFilterType.Exclude
    local parts = Workspace:GetPartBoundsInBox(root.CFrame * CFrame.new(0, -1.5, 0), Vector3.new(3.2, 3.5, 3.2), p)
    local unique, seen = 0, {}
    for _, pt in pairs(parts) do
        if pt.CanCollide and not seen[pt] then
            seen[pt] = true
            unique = unique + 1
        end
    end
    return unique
end

-- Infinite Jump listener (always on when mode 1 + enabled)
UserInputService.JumpRequest:Connect(function()
    if not enabled or currentMode ~= 1 then return end
    
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end
    
    local now = tick()
    if now - mode1_lastJump < mode1_cooldown then return end
    
    if not hasWall(root) then return end  -- Only boost near wall
    
    mode1_lastJump = now
    
    -- Force jump + velocity assist
    hum:ChangeState(Enum.HumanoidStateType.Jumping)
    local vel = root.AssemblyLinearVelocity
    root.AssemblyLinearVelocity = Vector3.new(vel.X, 55 + math.random(-3, 4), vel.Z)  -- Stronger boost for chaining
end)

RunService.Heartbeat:Connect(function()
    if not enabled then return end
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end

    if currentMode == 2 then
        -- Mode 2: Camera Flick (modified: normal/full jump power, no decay)
        if hum.FloorMaterial ~= Enum.Material.Air then mode2_jumpChain = 0 end
        if (UserInputService:IsKeyDown(Enum.KeyCode.Space) or hum.Jump) and mode2_jumpChain < mode2_settings.maxChain then
            local now = tick()
            if (now - mode2_lastJumpTime) >= mode2_settings.cooldown then
                if getContact(char, root) >= 2 then
                    mode2_lastJumpTime = now
                    mode2_jumpChain = mode2_jumpChain + 1
                    local camera = Workspace.CurrentCamera
                    local randomAngle = math.rad(90 + math.random(-4, 4))
                    local oldCF = root.CFrame
                    root.CFrame = oldCF * CFrame.Angles(0, randomAngle, 0)
                    camera.CFrame = camera.CFrame * CFrame.Angles(0, randomAngle, 0)
                    local vel = root.AssemblyLinearVelocity
                    root.AssemblyLinearVelocity = Vector3.new(vel.X, 50, vel.Z)  -- <-- Changed: fixed normal jump power (no decay)
                    task.delay(mode2_settings.snapDuration, function()
                        if root and root.Parent then
                            root.CFrame = oldCF
                            camera.CFrame = camera.CFrame * CFrame.Angles(0, -randomAngle, 0)
                        end
                    end)
                end
            end
        end
    end
end)

player.CharacterAdded:Connect(function()
    task.wait(1)
    local char = player.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum and not enabled then
            hum.JumpPower = 50
            hum.UseJumpPower = true
        end
    end
end)

